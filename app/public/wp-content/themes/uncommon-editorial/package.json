{
	"name": "uncommon-editorial",
	"version": "1.0.0",
	"description": "Uncommon Editorial WordPress Theme",
	"author": "Turtle Lasagne",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"WordPress",
		"Theme"
	],
	"homepage": "",
	"engines": {
		"node": ">=20.10.0",
		"npm": ">=10.2.3"
	},
	"devDependencies": {
		"@prettier/plugin-php": "^0.24.0",
		"@wordpress/browserslist-config": "^6.34.0",
		"@wordpress/scripts": "^27.1.0",
		"cssnano": "^7.1.2",
		"postcss": "^8.5.6",
		"postcss-cli": "^11.0.1",
		"sass": "^1.86.0"
	},
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"scripts": {
		"build-blocks": "node blocks-build.js",
		"watch-blocks": "node blocks-watch.js",
		"build": "postcss style.css --use cssnano -o style.min.css --no-map",
		"watch": "postcss style.css --use cssnano -o style.min.css --no-map --watch"
	}
}
